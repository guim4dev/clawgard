# Generated
/spec-go/generated.go
/spec-ts/src/generated.ts
/server/web/dist/
# Embedded SPA build output. A placeholder index.html is checked in so that
# //go:embed all:dist compiles on fresh clones without requiring `make
# dashboard-build` first. The Makefile dashboard-build target overwrites it
# with the real Vite output, along with assets/.
/server/internal/web/dist/*
!/server/internal/web/dist/index.html

